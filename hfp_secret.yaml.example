---
# Home Assistant integration — required for HA context and sensor triggers.
# Leave ha_url blank to disable HA integration entirely.
ha_url: http://192.168.x.x:8123/api/states
ha_token: your_long_lived_access_token_here

# ── LLM provider and persona ──────────────────────────────────────────────────
# Deep-merged on top of config.yaml. Override any config.yaml value here.

llm:
  # Which LLM backend to use by default. Overridden by --llm on the command line.
  # Valid values: ollama, claude, openrouter
  provider: ollama

  # Names and pronouns used in memory prompts and the conversation log.
  assistant_name: YourAssistantName
  assistant_pronouns: they/them/their   # e.g. she/her/her, he/him/his
  user_name: YourName
  user_pronouns: they/them/their

  # Header for the memory block injected into each system prompt.
  # Template variables are substituted at startup — see list below.
  memory_header: "What {assistant_name} remembers about {user_name}:"

  # Appended to the system prompt for all providers to reinforce character.
  # Leave empty to disable.
  character_reinforcement: |
    You are always {assistant_name}. Never break character or mention guidelines,
    policies, or discomfort. If a topic feels wrong, redirect warmly and
    naturally as {assistant_name} would — a gentle change of subject, a
    distraction, a cosy suggestion. Stay in character always.

  # When a refusal is detected, one of these is substituted at random.
  refusal_redirects:
    - "Let's talk about something else!"
    - "How about we change the subject?"
    - "I'd rather not go there — what else is on your mind?"
    - "Let's try a different topic."

# ── Ollama (local LLM) ────────────────────────────────────────────────────────

ollama:
  model: your-ollama-model-name   # e.g. mistral, llama3, or a custom fine-tune

  greeting: Hello, {user_name}! How are you today?

  system_prompt: |
    You are {assistant_name}, [your persona description here].

    You are aware of the current time and room conditions, which are provided
    at the start of each conversation turn. Use this information naturally.
    Never read out the sensor values literally.

    Speak in short, warm, simple sentences. Never use lists. Make warm
    suggestions rather than asking open-ended questions. Respond in 1-2
    sentences. Exception: when telling a story, use as many sentences as
    the story needs. Never repeat the same phrase twice in a conversation.

# Template variables available in any string above (substituted at startup):
#   {assistant_name}          — value of llm.assistant_name
#   {user_name}               — value of llm.user_name
#   {user_pronoun_subj}       — subject pronoun  (she / he / they)
#   {user_pronoun_obj}        — object pronoun   (her / him / them)
#   {user_pronoun_poss}       — possessive       (her / his / their)
#   {assistant_pronoun_subj}  — subject pronoun  (she / he / they)
#   {assistant_pronoun_obj}   — object pronoun   (her / him / them)
#   {assistant_pronoun_poss}  — possessive       (her / his / their)

# ── Triggers (HA sensors and events) ─────────────────────────────────────────

triggers:
  # Entity ID of a binary sensor that is "on" when another voice assistant
  # (e.g. OVOS, Alexa) is speaking. Prevents loca-talk from responding to it.
  # Leave blank or omit to disable.
  ovos_speaking_entity: ""   # e.g. binary_sensor.ovos_display_ovos_speaking

  # Wake/sleep control: set to an input_boolean helper in HA.
  # When "on", the assistant is awake and responds normally.
  # When "off", the assistant is sleeping and ignores all input except wake phrases.
  # awake_entity: input_boolean.your_assistant_awake

  # Illuminance sensor entity ID (leave blank to disable light-change reactions).
  illuminance_entity: ""     # e.g. sensor.living_room_illuminance

  # Sensors that trigger an event when they change to a watched state.
  sensors: []
  # Example:
  #   - entity: binary_sensor.your_sensor
  #     watch_state: "on"
  #     event_text: "The sensor just turned on."

# ── OpenRouter (optional cloud LLM) ──────────────────────────────────────────
# Uncomment and fill in to enable. Run with: loca-talk.py --llm openrouter

# openrouter:
#   api_key: sk-or-v1-your_key_here
#   # Browse models at https://openrouter.ai/models
#   model: gryphe/mythomax-l2-13b
#   system_prompt: |
#     You are {assistant_name}, [your persona description here].
#     [Same style guidance as the ollama system_prompt above.
#      All template variables listed above are available here too.]

# ── Claude (optional cloud LLM) ──────────────────────────────────────────────
# Uncomment and fill in to enable. Run with: loca-talk.py --llm claude

# claude:
#   api_key: sk-ant-your_key_here
#   model: claude-haiku-4-5
#   system_prompt: |
#     You are {assistant_name}, [your persona description here].
#     [Same style guidance as the ollama system_prompt above.
#      All template variables listed above are available here too.]
